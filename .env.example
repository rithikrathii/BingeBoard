# .env.example
# Copy this file to .env and fill in real values.
# Do NOT commit the real .env file.

# MongoDB Atlas connection for the movie catalogue service
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/
MONGO_DB=sample_mflix

# Service ports
AUTH_PORT=8000
MOVIE_CATALOGUE_PORT=8001
RATINGS_PORT=8002

# Auth service
JWT_SECRET_KEY=change-this-secret-key-at-least-32-bytes-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL auth database
# Docker Compose uses its own internal DATABASE_URL for auth-service.
DATABASE_URL=postgresql://auth_user:auth_password@localhost:5433/auth_db
