# .env.example
# Copy this file to .env and fill in real values

# Shared MongoDB Atlas cluster (use our string here)
MONGO_URI=mongodb+srv://movieapp:OUR_PASSWORD@cluster0.xxxxx.mongodb.net/
MONGO_DB=sample_mflix

# Service ports
MOVIE_CATALOGUE_PORT=8001
RATINGS_PORT=8002
AUTH_PORT=8000

# Auth service
JWT_SECRET=jwt_secret_here
POSTGRES_URL=postgresql://user:password@localhost:5432/authdb